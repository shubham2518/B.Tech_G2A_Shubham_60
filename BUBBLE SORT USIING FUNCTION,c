#include<stdio.h>

void bubblesort(int a[], int n) {
  
  int i, j;
  for(i=0; i<n-1; i++){
    for(j=0; j<n-i-1; j++){
      if(a[j] > a[j+1]){

        int temp = a[j];
        a[j] = a[j+1];
        a[j+1] = temp;
      }
    }
  }
}

// Calling function
int main() {
  
  int a[] = {5,3,4,2,1};
  int n = 5;
  int i, j;

  bubblesort(a, n);

  printf("Sorted Array : ");
  for(i=0; i<n; i++){
    printf("%d ",a[i]);
  }
  return 0;
}
